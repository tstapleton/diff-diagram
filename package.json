    "@types/node": "22.15.21",
    "@types/pixelmatch": "5.2.6",
    "@types/pngjs": "6.0.5",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  }
}
