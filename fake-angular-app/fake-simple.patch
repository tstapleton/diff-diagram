@@ -20,4 +20,12 @@ export class UsersService {
   delete(id: string): Observable<void> {
     return this.api.delete<void>(`${this.base}/${id}`);
   }
+
+  bulkUpdate(ids: string[], partial: Partial<UserModel>): Observable<UserModel[]> {
+    return this.api.post<UserModel[]>(`${this.base}/bulk`, { ids, data: partial });
+  }
+
+  search(query: string): Observable<UserModel[]> {
+    return this.api.get<UserModel[]>(`${this.base}?q=${encodeURIComponent(query)}`);
+  }
 }
