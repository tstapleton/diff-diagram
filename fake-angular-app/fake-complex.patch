+import { Component, Input } from '@angular/core';
+import { CommonModule } from '@angular/common';
+import { UserExportService } from './user-export.service';
+import { ExportModel } from './export.model';
+import { UserModel } from '../models/user.model';
+
+@Component({
+  selector: 'app-user-bulk-export',
+  standalone: true,
+  imports: [CommonModule],
+  template: `
+    <div class="bulk-export">
+      <button (click)="exportAll()">Export All ({{ users.length }})</button>
+      <button (click)="exportSelected()" [disabled]="!selectedIds.length">
+        Export Selected ({{ selectedIds.length }})
+      </button>
+    </div>
+  `,
+})
+export class UserBulkExportComponent {
+  @Input() users: UserModel[] = [];
+  @Input() selectedIds: string[] = [];
+
+  constructor(private exportService: UserExportService) {}
+
+  exportAll(): void {
+    const config: ExportModel = { format: 'csv', fields: ['id', 'email', 'firstName', 'lastName'], filename: 'all-users.csv' };
+    this.exportService.export(this.users, config).subscribe();
+  }
+
+  exportSelected(): void {
+    const selected = this.users.filter(u => this.selectedIds.includes(u.id));
+    const config: ExportModel = { format: 'csv', fields: ['id', 'email', 'firstName', 'lastName'], filename: 'selected-users.csv' };
+    this.exportService.export(selected, config).subscribe();
+  }
+}
